    {
      "name": "Navigation Works",
      "priority": "high",
      "description": "Click through nav links, verify no 404s or crashes",
      "steps": [
        {
          "action": "navigate",
          "url": "/"
        },
        {
          "action": "collect_links",
          "selector": "nav a, header a, [role=\"navigation\"] a"
        },
        {
          "action": "click_each_link",
          "selector": "nav a, header a",
          "expect": {
            "no_404": true,
            "no_crash": true
          }
        }
      ]
    },
    {
      "name": "Auth Flow",
      "priority": "high",
      "description": "Visit login page, verify form renders, attempt login",
      "steps": [
        {
          "action": "navigate",
          "url": "/login"
        },
        {
          "action": "assert_visible",
          "selector": "form, [role=\"form\"]"
        },
        {
          "action": "assert_interactive",
          "selector": "input[type=\"email\"], input[name=\"email\"], input[type=\"text\"]"
        },
        {
          "action": "assert_interactive",
          "selector": "button[type=\"submit\"], input[type=\"submit\"]"
        },
        {
          "action": "fill",
          "selector": "input[type=\"email\"], input[name=\"email\"], input[type=\"text\"]",
          "value": "{{TEST_EMAIL}}"
        },
        {
          "action": "fill",
          "selector": "input[type=\"password\"], input[name=\"password\"]",
          "value": "{{TEST_PASSWORD}}"
        },
        {
          "action": "click",
          "selector": "button[type=\"submit\"]"
        },
        {
          "action": "wait",
          "value": "2000"
        },
        {
          "action": "screenshot"
        }
      ]
    },
