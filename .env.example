# =============================================================================
# Protekon — Environment Variables
# Copy to .env.local and fill in real values
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase Publishable Key (Vercel integration)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co

# Postgres (direct connection — used by migrations/scripts)
POSTGRES_URL=postgres://user:pass@host:6543/postgres
POSTGRES_URL_NON_POOLING=postgres://user:pass@host:5432/postgres
POSTGRES_PRISMA_URL=postgres://user:pass@host:6543/postgres?pgbouncer=true
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DATABASE=postgres

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_MCP_KEY=ek_test_xxx

# Subscription prices resolve via Stripe lookup keys (protekon_core_monthly,
# protekon_professional_monthly, protekon_multi-site_monthly) — set those on
# the Price objects in Stripe Dashboard. No price IDs in env.
STRIPE_SETUP_CORE=price_xxx
STRIPE_SETUP_PROFESSIONAL=price_xxx
STRIPE_SETUP_MULTI_SITE=price_xxx

# --- Inngest ---
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=signkey-prod-xxx

# --- Resend (Email) ---
RESEND_API_KEY=re_xxx
# FROM address used by lib/resend.ts. Domain MUST be `verified` in Resend dashboard.
# Default is "Protekon <compliance@protekon.org>"; override per environment.
RESEND_FROM=Protekon <compliance@protekon.org>
# Recipient for /api/health/integrations alerts when an integration check fails.
RESEND_ALERT_TO=ops@protekon.org

# --- Health probe (cron) ---
# Long random string. /api/health/integrations requires this in the x-health-secret
# header so the endpoint isn't a public probe target.
HEALTH_CHECK_SECRET=replace-with-long-random-string

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# --- Sanity (CMS) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_PROJECT_ID=your-project-id
SANITY_API_DATASET=production
SANITY_API_READ_TOKEN=your-read-token
SANITY_API_WRITE_TOKEN=your-write-token
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# --- Vercel Blob (File Storage) ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# --- Upstash Vector ---
UPSTASH_VECTOR_REST_URL=https://your-index.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your-admin-token
UPSTASH_VECTOR_REST_READONLY_TOKEN=your-readonly-token

# --- OSHA Data API (Supabase Edge Function on OSHA project) ---
OSHA_API_URL=https://your-osha-project.supabase.co/functions/v1/protekon-api
OSHA_API_KEY=your-api-key

# --- OSHA Scraper DB (read-only fallback for enforcement widgets) ---
# Points at the cli-ai-scraper Supabase project. Consumed by lib/supabase/scraper.ts.
# Use the anon key — RLS policies enforce read-only access.
OSHA_SCRAPER_SUPABASE_URL=https://vizmtkfpxxjzlpzibate.supabase.co
OSHA_SCRAPER_SUPABASE_KEY=your-scraper-anon-key

# --- Scraper project (read-only mirror source for nightly intelligence sync) ---
# Consumed by lib/supabase/scraper.ts (createScraperServiceClient) and called
# exclusively from inngest/functions/mirror-intelligence-nightly.ts (NGE-481).
# Service-role key is foreign-project admin — never expose to the browser.
SCRAPER_SUPABASE_URL=https://vizmtkfpxxjzlpzibate.supabase.co
SCRAPER_SUPABASE_SERVICE_ROLE_KEY=your-scraper-service-role-key

# --- Vercel (auto-populated on Vercel) ---
# VERCEL_OIDC_TOKEN= (auto-injected by Vercel)
# NEXT_PUBLIC_APP_URL= (set per environment)
